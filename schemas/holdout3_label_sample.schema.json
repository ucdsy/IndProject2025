{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentdns.local/schemas/holdout3_label_sample.schema.json",
  "title": "Holdout3LabelSample",
  "type": "object",
  "required": [
    "id",
    "family_id",
    "ground_truth_fqdn",
    "acceptable_fqdns",
    "relevant_fqdns",
    "eval_bucket",
    "bucket_tags",
    "intent_form",
    "surface_style",
    "primary_granularity",
    "secondary_intent_present",
    "high_risk_case",
    "notes_for_audit"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "family_id": {
      "type": "string"
    },
    "ground_truth_fqdn": {
      "type": "string",
      "pattern": "^(?:[a-z0-9-]+\\.){1,3}cn$"
    },
    "acceptable_fqdns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(?:[a-z0-9-]+\\.){1,3}cn$"
      }
    },
    "relevant_fqdns": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?:[a-z0-9-]+\\.){1,3}cn$"
      }
    },
    "eval_bucket": {
      "type": "string",
      "enum": [
        "ordinary_fast_path",
        "sibling_hierarchy",
        "primary_secondary_disentanglement",
        "cross_domain_overlap",
        "high_risk_governance"
      ]
    },
    "bucket_tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "intent_form": {
      "type": "string",
      "enum": [
        "direct_request",
        "scene_description",
        "stepwise_instruction",
        "constraint_first",
        "goal_then_support"
      ]
    },
    "surface_style": {
      "type": "string",
      "enum": [
        "colloquial",
        "formal",
        "enterprise",
        "compressed",
        "indirect",
        "mixed"
      ]
    },
    "primary_granularity": {
      "type": "string",
      "enum": [
        "base",
        "segment"
      ]
    },
    "secondary_intent_present": {
      "type": "boolean"
    },
    "high_risk_case": {
      "type": "boolean"
    },
    "notes_for_audit": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
