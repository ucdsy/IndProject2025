{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentdns.local/schemas/holdout2_label_sample.schema.json",
  "title": "Holdout2LabelSample",
  "type": "object",
  "required": [
    "id",
    "family_id",
    "ground_truth_fqdn",
    "acceptable_fqdns",
    "relevant_fqdns",
    "intended_confusion_types",
    "primary_granularity",
    "secondary_intent_present",
    "high_risk_case",
    "notes_for_audit"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "family_id": {
      "type": "string"
    },
    "ground_truth_fqdn": {
      "type": "string",
      "pattern": "^(?:[a-z0-9-]+\\.){1,3}cn$"
    },
    "acceptable_fqdns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(?:[a-z0-9-]+\\.){1,3}cn$"
      }
    },
    "relevant_fqdns": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?:[a-z0-9-]+\\.){1,3}cn$"
      }
    },
    "intended_confusion_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "multi_intent",
          "lexical_overlap",
          "sibling_competition",
          "governance_fallback",
          "cross_domain_overlap",
          "fallback"
        ]
      }
    },
    "primary_granularity": {
      "type": "string",
      "enum": [
        "base",
        "segment"
      ]
    },
    "secondary_intent_present": {
      "type": "boolean"
    },
    "high_risk_case": {
      "type": "boolean"
    },
    "notes_for_audit": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
