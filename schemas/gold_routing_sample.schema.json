{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentdns.local/schemas/gold_routing_sample.schema.json",
  "title": "GoldRoutingSample",
  "description": "Gold routing sample. All fqdn fields must already use canonical routing_fqdn representation, including l3 as <segment>.<l2>.<l1>.cn.",
  "type": "object",
  "required": [
    "id",
    "family_id",
    "namespace_version",
    "query",
    "constraints",
    "ground_truth_fqdn"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "family_id": {
      "type": "string",
      "description": "Query family identifier used for split hygiene. Same family_id must not cross dev/blind/challenge."
    },
    "namespace_version": {
      "type": "string"
    },
    "query": {
      "type": "string"
    },
    "context": {
      "type": "object"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ground_truth_fqdn": {
      "type": "string",
      "pattern": "^(?:[a-z0-9-]+\\.){1,3}cn$",
      "description": "Canonical primary routing_fqdn."
    },
    "relevant_fqdns": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?:[a-z0-9-]+\\.){1,3}cn$"
      }
    },
    "acceptable_fqdns": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?:[a-z0-9-]+\\.){1,3}cn$"
      }
    },
    "difficulty_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "intended_confusion_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
